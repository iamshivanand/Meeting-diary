{
  "name": "meeting-recorder",
  "version": "1.0.0",
  "description": "Local-first meeting recorder with speaker diarization and transcription",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload && npm run build:resources && npm run build:sidecar",
    "build:renderer": "vite build --mode production",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:resources": "node scripts/create-resources.js",
    "build:sidecar": "python scripts/build_sidecar.py",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:dev": "concurrently -k --success first \"npm run dev:vite\" \"wait-on tcp:5173 && npx playwright test --config tests/e2e/playwright.config.ts\"",
    "lint": "eslint src --ext ts,tsx",
    "start": "npm run build && electron .",
    "pack": "npm run build && cross-env SIGNTOOL_PATH=dummy npx electron-builder --dir",
    "pack:dist": "npm run build && cross-env SIGNTOOL_PATH=dummy npx electron-builder",
    "postinstall": "node scripts/install-native-deps.js"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "eventemitter3": "^5.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "1.10",
    "uuid": "^9.0.1",
    "wavesurfer.js": "^7.12.8",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.meetingrecorder.app",
    "productName": "Meeting Recorder",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sidecar/dist",
        "to": "sidecar",
        "filter": [
          "**/*",
          "!**/tests/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/benchmarks.py"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "iamshivanand",
      "repo": "Meeting-diary",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icons/icon.png",
      "signDlls": false,
      "signAndEditExecutable": false,
      "publish": [
        "github"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icons/icon.png",
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
